{
  "name": "agent-protocol",
  "version": "1.0.0",
  "description": "A universal protocol for AI agent communication - Like TCP/IP for AI agents",
  "license": "MIT",
  "type": "module",
  "main": "./dist/protocol.js",
  "types": "./dist/protocol.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint src/**/*.ts",
    "docs": "typedoc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "protocol",
    "multi-agent",
    "communication",
    "interoperability",
    "standard",
    "tcp-ip"
  ],
  "author": "moggan1337",
  "repository": {
    "type": "git",
    "url": "https://github.com/moggan1337/agent-protocol"
  },
  "bugs": {
    "url": "https://github.com/moggan1337/agent-protocol/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/protocol.js",
      "types": "./dist/protocol.d.ts"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typedoc": "^0.25.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
